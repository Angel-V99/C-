	// R: B vale 20 y c vale -80.

	// ¿A dónde apuntan p, q y m?
	// R: P y q apuntan al primer elemento, en el caso de q quedo asi luego de que se le recorriera un valor hacia atras al definir b. M apunta al 5to elemento del arreglo, 50.

	c = (*(p + 3) - b * c + *(q + 5) - *(m - 1)) * c;

	cout << "Valor de b: " << b << " ---> Posicion en el arreglo." << endl;
