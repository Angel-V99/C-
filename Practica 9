#include <iostream>
using namespace std;
struct Nodo {
    int dato;
    Nodo* siguiente;
};
void agregar(Nodo*& cabeza, int valor) {
    Nodo* nuevo = new Nodo();
    nuevo->dato = valor;
    nuevo->siguiente = cabeza;
    cabeza = nuevo;
}
Nodo* buscar(Nodo* cabeza, int valor) {
    Nodo* actual = cabeza;
    while (actual != NULL) {
        if (actual->dato == valor) {
            return actual;
        }
        actual = actual->siguiente;
    }
    return NULL;
}
void modificar(Nodo* nodo, int nuevoValor) {
    nodo->dato = nuevoValor;
}
void eliminar(Nodo*& cabeza, int valor) {
    Nodo* actual = cabeza;
    Nodo* anterior = NULL;
    while (actual != NULL && actual->dato != valor) {
        anterior = actual;
        actual = actual->siguiente;
    }
    if (actual == NULL) return;
    if (anterior == NULL) {
        cabeza = actual->siguiente;
    }
    else {
        anterior->siguiente = actual->siguiente;
    }
    delete actual;
}
void mostrar(Nodo* cabeza) {
    Nodo* actual = cabeza;
    while (actual != NULL) {
        cout << actual->dato << " -> ";
        actual = actual->siguiente;
    }
    cout << "NULL" << endl;
}
int main() {
    Nodo* lista = NULL;
    int opcion, valor, nuevoValor;
    do {
        cout << "\nMENU\n";
        cout << "1. Agregar\n";
        cout << "2. Buscar\n";
        cout << "3. Modificar\n";
        cout << "4. Eliminar\n";
        cout << "5. Mostrar lista\n";
        cout << "6. Salir\n";
        cout << "Opcion: ";
        cin >> opcion;
        switch (opcion) {
        case 1:
            cout << "Valor a agregar: ";
            cin >> valor;
            agregar(lista, valor);
            break;
        case 2:
            cout << "Valor a buscar: ";
            cin >> valor;
            if (buscar(lista, valor))
                cout << "Elemento encontrado\n";
            else
                cout << "Elemento no encontrado\n";
            break;
        case 3:
            cout << "Valor a modificar: ";
            cin >> valor;
            if (buscar(lista, valor)) {
                cout << "Nuevo valor: ";
                cin >> nuevoValor;
                modificar(buscar(lista, valor), nuevoValor);
            }
            else {
                cout << "Elemento no encontrado\n";
            }
            break;
        case 4:
            cout << "Valor a eliminar: ";
            cin >> valor;
            eliminar(lista, valor);
            break;
        case 5:
            mostrar(lista);
            break;
        }
    } while (opcion != 6);
    return 0;
}
